{
  "name": "dj1000-converter-web",
  "private": true,
  "version": "0.1.0",
  "description": "Windows 98-inspired photo culling and editing app for Mitsubishi DJ-1000 / UMAX PhotoRun DAT files.",
  "type": "module",
  "main": "electron-dist/main.js",
  "scripts": {
    "sync:vendor": "node ./scripts/sync-dj1000-vendor.mjs",
    "dev": "npm run sync:vendor && vite --host 127.0.0.1 --port 5173",
    "dev:electron": "npm run sync:vendor && concurrently -k -n renderer,electron-ts,electron \"vite --host 127.0.0.1 --port 5173\" \"tsc -p electron/tsconfig.json --watch --preserveWatchOutput\" \"wait-on tcp:5173 file:electron-dist/main.js && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electronmon electron-dist/main.js\"",
    "build:renderer": "npm run sync:vendor && tsc -b && vite build && node ./scripts/copy-pages-fallback.mjs",
    "build:electron": "tsc -p electron/tsconfig.json",
    "build": "npm run build:renderer && npm run build:electron",
    "build:pages": "npm run build:renderer",
    "typecheck": "tsc -b && tsc -p electron/tsconfig.json --noEmit",
    "lint": "eslint .",
    "preview": "vite preview",
    "preview:electron": "npm run build && electron electron-dist/main.js",
    "dist:electron": "npm run build && electron-builder"
  },
  "dependencies": {
    "98.css": "^0.1.21",
    "jszip": "^3.10.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "electronmon": "^2.0.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.dj1000.converter.web",
    "productName": "DJ1000 Converter Web",
    "files": [
      "dist/**/*",
      "electron-dist/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "public"
    },
    "mac": {
      "target": "dir"
    },
    "win": {
      "target": "dir"
    },
    "linux": {
      "target": "dir"
    }
  }
}
